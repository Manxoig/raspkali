#!/bin/sh
# postinst script for raspkali-widget

set -e

# Crear directorio de logs con permisos restringidos
mkdir -p /var/log/raspkali-widget
chmod 750 /var/log/raspkali-widget
chown root:adm /var/log/raspkali-widget

# Ajustar permisos
chmod 755 /usr/bin/raspkali-widget
chmod 755 /usr/bin/raspkali-widget-ctl

# dh_installdeb will replace this with shell code automatically
# generated by other debhelper scripts.

#DEBHELPER#

exit 0