#!/bin/sh
# raspkali-widget-ctl - Script de control para raspkali-widget
# Conforme a Debian Policy 9.3 (scripts de control de servicios de usuario)

NAME="raspkali-widget"
EXEC="/usr/bin/ventana.py"
PIDFILE="${XDG_RUNTIME_DIR:-/tmp}/raspkali-widget.pid"

get_pid() {
    [ -f "$PIDFILE" ] && cat "$PIDFILE"
}

is_running() {
    pid=$(get_pid)
    [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null
}

cmd_start() {
    if is_running; then
        echo "$NAME ya está en ejecución (PID $(get_pid))"
        return 0
    fi
    "$EXEC" &
    echo "$NAME iniciado"
}

cmd_stop() {
    if ! is_running; then
        echo "$NAME no está en ejecución"
        return 0
    fi
    kill "$(get_pid)"
    rm -f "$PIDFILE"
    echo "$NAME detenido"
}

cmd_restart() {
    cmd_stop
    sleep 1
    cmd_start
}

cmd_status() {
    if is_running; then
        echo "$NAME en ejecución (PID $(get_pid))"
    else
        echo "$NAME detenido"
        return 1
    fi
}

case "$1" in
    start)   cmd_start   ;;
    stop)    cmd_stop    ;;
    restart) cmd_restart ;;
    status)  cmd_status  ;;
    *)
        echo "Uso: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac
